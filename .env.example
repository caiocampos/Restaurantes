# Porta do servidor
PORT=3000

# String de conexão do MongoDB
MONGO_URI=mongodb://localhost:27017
# MONGO_URI_RESTAURANTS=mongodb://localhost:27017

# Nome do banco de dados usado dentro da conexão acima
DB_NAME=restaurantes

# Segredo usado para assinar os tokens JWT (troque por um valor forte em produção)
JWT_SECRET=troque-este-valor-por-um-segredo-forte

# Validade do token
JWT_EXPIRES_IN=24h
